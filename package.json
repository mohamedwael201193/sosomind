{
  "name": "sosomind",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm --workspace @sosomind/backend run dev",
    "dev:dashboard": "npm --workspace @sosomind/dashboard run dev",
    "build": "npm run build --workspaces --if-present",
    "mcp:sosovalue": "npm --workspace @sosomind/mcp-sosovalue start",
    "mcp:sodex": "npm --workspace @sosomind/mcp-sodex start"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0"
  }
}
