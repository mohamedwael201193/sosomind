# ── SoSoValue ─────────────────────────────────────────────────────────────────
SOSO_API_KEY=your-primary-sosovalue-api-key
# Backup keys — tried in order when primary is rate-limited (402901 / 429)
SOSO_API_KEY_FALLBACK=your-second-sosovalue-api-key
SOSO_API_KEY_FALLBACK_2=your-third-sosovalue-api-key
# Or comma-separated (max priority order): SOSO_API_KEYS=key1,key2,key3

# ── SoDEX ─────────────────────────────────────────────────────────────────────
SODEX_CHAIN_ID=138565
SODEX_PRIVATE_KEY=                        # Your EVM private key (0x...)
SODEX_ADDRESS=                            # Your wallet address (0x...)
SODEX_ACCOUNT_ID=                         # Same as SODEX_ADDRESS usually
SODEX_API_KEY_NAME=                       # Register on SoDEX UI → API Keys
DRY_RUN=true                              # Set false for live trading

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=                # From Supabase dashboard → Settings → API

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_CHAT_ID=your-chat-id-here
TELEGRAM_CHANNEL_ID=                      # Your publish channel ID e.g. @mychannel

# ── AI Providers ──────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here
GROQ_API_KEY=gsk_your-groq-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=10000
WS_PORT=10001
CRON_SECRET=                              # Set a random secret for /api/cron/heartbeat
NODE_ENV=production

# ── Auth (per-user non-custodial) ────────────────────────────────────────────
JWT_SECRET=                               # 32+ char random string for SIWE JWT (HS256)
DASHBOARD_URL=http://localhost:3000       # Used by bot for /trade/sign deep links
CORS_ALLOWED_ORIGINS=http://localhost:3000  # Comma-separated allowlist

# ── Dashboard (Next.js) ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:10000
NEXT_PUBLIC_WS_URL=ws://localhost:10001
